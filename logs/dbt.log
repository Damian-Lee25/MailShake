        payload:from.address::string           as from_address,
        payload:from.first::string             as from_first_name,
        payload:from.last::string              as from_last_name,
        payload:from.fullName::string          as from_full_name,

        -- recipient info
        payload:recipient.id::int                   as recipient_id,
        payload:recipient.contactID::int           as recipient_contact_id,
        payload:recipient.emailAddress::string     as recipient_email,
        payload:recipient.first::string            as recipient_first_name,
