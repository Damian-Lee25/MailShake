  create or replace view `mailshake-analysis-486717`.`SILVER`.`stg_mailshake_team_members`
  OPTIONS()
  as 

WITH source AS (
    SELECT * 
    FROM `mailshake-analysis-486717`.`BRONZE`.`team_members`
    
),

parsed AS (

    SELECT
        -- ingestion metadata
        team_id AS api_team_id,
        extracted_at,
        source_endpoint,

        -- primary identifier
        CAST(JSON_VALUE(payload, '$.id') AS INT64) AS member_id,

        -- personal info
        JSON_VALUE(payload, '$.emailAddress') AS email_address,
        JSON_VALUE(payload, '$.first') AS first_name,
        JSON_VALUE(payload, '$.last') AS last_name,
        JSON_VALUE(payload, '$.fullName') AS full_name,

        -- status / role flags
        CAST(JSON_VALUE(payload, '$.isDisabled') AS BOOL) AS is_disabled,
        CAST(JSON_VALUE(payload, '$.isTeamAdmin') AS BOOL) AS is_team_admin,
        JSON_VALUE(payload, '$.object') AS object_type,

        -- reference to team
        CAST(JSON_VALUE(payload, '$.teamID') AS INT64) AS team_id,

        -- add row number for deduplication
        QUALIFY ROW_NUMBER() OVER (
        PARTITION BY CAST(JSON_VALUE(payload, '$.id') AS INT64)
        ORDER BY extracted_at DESC
    ) = 1

)

SELECT *
FROM parsed;


