        payload:recipient.created::timestamp_ntz   as recipient_created_at,
        payload:recipient.isPaused::boolean        as recipient_is_paused,

        -- recipient custom fields
        payload:recipient.fields.account::string    as account,
        payload:recipient.fields.position::string   as position,
        payload:recipient.fields.link::string       as job_link,
        payload:recipient.fields.phoneNumber::string as phone_number,
