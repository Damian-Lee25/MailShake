    create or replace table `mailshake-analysis-486717`.`GOLD`.`fct_campaign_performance_revised`
      
    
    

    
    OPTIONS()
    as (
      

WITH campaigns AS (
    SELECT 
        campaign_id,
        team_id,
        campaign_title,
        created_at,
        wizard_status,
        sender_email,
        is_archived,
        is_paused
    FROM `mailshake-analysis-486717`.`SILVER`.`stg_mailshake_campaigns`
),

-- Pre-aggregate activity metrics (much faster!)
sent_metrics AS (
    SELECT
        campaign_id,
        COUNT(DISTINCT recipient_id) AS total_recipients,
        COUNT(sent_id) AS emails_sent,
        MIN(action_date) AS first_sent_at,
        MAX(action_date) AS last_sent_at
    FROM `mailshake-analysis-486717`.`SILVER`.`stg_mailshake_activity_sent`
    GROUP BY campaign_id
),

open_metrics AS (
    SELECT
        campaign_id,
        COUNT(open_id) AS total_opens,
        COUNT(DISTINCT recipient_id) AS unique_openers
    FROM `mailshake-analysis-486717`.`SILVER`.`stg_mailshake_activity_opens`
    GROUP BY campaign_id
),

click_metrics AS (
    SELECT
        campaign_id,
        COUNT(click_id) AS total_clicks,
        COUNT(DISTINCT recipient_id) AS unique_clickers
    FROM `mailshake-analysis-486717`.`SILVER`.`stg_mailshake_activity_clicks`
    GROUP BY campaign_id
),

senders AS (
    SELECT
        sender_id,
        from_name,
        is_verified
    FROM `mailshake-analysis-486717`.`SILVER`.`stg_mailshake_senders`
),

reply_metrics AS (
    SELECT
        campaign_id,
        COUNT(CASE WHEN reply_type = 'reply' THEN reply_id END) AS total_replies,
        COUNT(DISTINCT CASE WHEN reply_type = 'reply' THEN recipient_id END) AS unique_repliers,
        COUNT(CASE WHEN reply_type = 'bounce' THEN reply_id END) AS total_bounces,
        COUNT(CASE WHEN reply_type = 'unsubscribe' THEN reply_id END) AS total_unsubscribes
    FROM `mailshake-analysis-486717`.`SILVER`.`stg_mailshake_activity_replies`
    GROUP BY campaign_id
)

SELECT
    -- Campaign info
    c.campaign_id,
    c.team_id,
    c.campaign_title,
    c.created_at AS campaign_created_at,
    c.wizard_status,
    c.sender_email,
    c.is_archived,
    c.is_paused,
    
    -- Volume metrics
    COALESCE(s.total_recipients, 0) AS total_recipients,
    COALESCE(s.emails_sent, 0) AS emails_sent,
    COALESCE(o.total_opens, 0) AS total_opens,
    COALESCE(o.unique_openers, 0) AS unique_openers,
    COALESCE(cl.total_clicks, 0) AS total_clicks,
    COALESCE(cl.unique_clickers, 0) AS unique_clickers,
    COALESCE(r.total_replies, 0) AS total_replies,
    COALESCE(r.unique_repliers, 0) AS unique_repliers,
    COALESCE(r.total_bounces, 0) AS total_bounces,
    COALESCE(r.total_unsubscribes, 0) AS total_unsubscribes,
    
    -- Timing
    s.first_sent_at,
    s.last_sent_at,
    
    -- Core rates (0-1 scale)
    SAFE_DIVIDE(o.unique_openers, s.emails_sent) AS open_rate,
    SAFE_DIVIDE(cl.unique_clickers, s.emails_sent) AS click_rate,
    SAFE_DIVIDE(r.unique_repliers, s.emails_sent) AS reply_rate,
    SAFE_DIVIDE(cl.unique_clickers, o.unique_openers) AS click_through_rate,
    SAFE_DIVIDE(r.total_bounces, s.emails_sent) AS bounce_rate,
    SAFE_DIVIDE(r.total_unsubscribes, s.emails_sent) AS unsubscribe_rate,
    
    -- Metadata
    CURRENT_TIMESTAMP() AS calculated_at

FROM campaigns c
LEFT JOIN sent_metrics s ON c.campaign_id = s.campaign_id
LEFT JOIN open_metrics o ON c.campaign_id = o.campaign_id
LEFT JOIN click_metrics cl ON c.campaign_id = cl.campaign_id
LEFT JOIN reply_metrics r ON c.campaign_id = r.campaign_id
    );
  
