[0m23:14:12.736341 [debug] [Thread-2 (]: On model.mailshake.daily_activity: create or replace transient table MAILSHAKE_DB.GOLD.daily_activity
    
    
    
    as (

WITH daily_sends AS (
    SELECT
        campaign_id,
        CAST(action_date AS DATE) AS activity_date,
        COUNT(*) AS emails_sent,
        COUNT(DISTINCT recipient_id) AS unique_recipients_sent
    FROM MAILSHAKE_DB.SILVER.stg_mailshake_activity_sent
    GROUP BY campaign_id, activity_date
),

daily_opens AS (
    SELECT
        campaign_id,
        CAST(action_date AS DATE) AS activity_date,
        COUNT(*) AS total_opens,
        COUNT(DISTINCT recipient_id) AS unique_openers
    FROM MAILSHAKE_DB.SILVER.stg_mailshake_activity_opens
    GROUP BY campaign_id, activity_date
),

daily_replies AS (
    SELECT
        campaign_id,
        CAST(action_date AS DATE) AS activity_date,
        
        COUNT(CASE WHEN reply_type = 'reply' THEN 1 END) AS total_replies,
        COUNT(DISTINCT CASE WHEN reply_type = 'reply' THEN recipient_id END) AS unique_repliers,
        
        COUNT(CASE WHEN reply_type = 'bounce' THEN 1 END) AS total_bounces,
        COUNT(DISTINCT CASE WHEN reply_type = 'bounce' THEN recipient_id END) AS unique_bounces,
        
        COUNT(CASE WHEN reply_type = 'unsubscribe' THEN 1 END) AS total_unsubscribes,
        COUNT(DISTINCT CASE WHEN reply_type = 'unsubscribe' THEN recipient_id END) AS unique_unsubscribes
        
    FROM MAILSHAKE_DB.SILVER.stg_mailshake_activity_replies
    GROUP BY campaign_id, activity_date
),

campaigns AS (
    SELECT
        campaign_id,
        team_id,
        campaign_title,
        sender_email
    FROM MAILSHAKE_DB.SILVER.stg_mailshake_campaigns
),

-- Create date spine with all dates that have activity
date_spine AS (
    SELECT DISTINCT activity_date
    FROM (
        SELECT activity_date FROM daily_sends
        UNION
        SELECT activity_date FROM daily_opens
        UNION
        SELECT activity_date FROM daily_replies
    )
),

-- Cross join campaigns with dates to get all possible combinations
campaign_dates AS (
    SELECT
        c.campaign_id,
        c.team_id,
        c.campaign_title,
        c.sender_email,
        d.activity_date
    FROM campaigns c
    CROSS JOIN date_spine d
),

final AS (
    SELECT
        cd.campaign_id,
        cd.team_id,
        cd.campaign_title,
        cd.sender_email,
        cd.activity_date,
        
        -- Add derived time dimensions
        DATE_TRUNC('week', cd.activity_date) AS week_start_date,
        DATE_TRUNC('month', cd.activity_date) AS month_start_date,
        DATE_TRUNC('quarter', cd.activity_date) AS quarter_start_date,
        YEAR(cd.activity_date) AS year,
        MONTH(cd.activity_date) AS month,
        DAYOFWEEK(cd.activity_date) AS day_of_week,
        DAYNAME(cd.activity_date) AS day_name,
        
        -- Volume metrics
        COALESCE(s.emails_sent, 0) AS emails_sent,
        COALESCE(s.unique_recipients_sent, 0) AS unique_recipients_sent,
        COALESCE(o.total_opens, 0) AS total_opens,
        COALESCE(o.unique_openers, 0) AS unique_openers,
        COALESCE(r.total_replies, 0) AS total_replies,
        COALESCE(r.unique_repliers, 0) AS unique_repliers,
        COALESCE(r.total_bounces, 0) AS total_bounces,
        COALESCE(r.unique_bounces, 0) AS unique_bounces,
        COALESCE(r.total_unsubscribes, 0) AS total_unsubscribes,
        COALESCE(r.unique_unsubscribes, 0) AS unique_unsubscribes,
        
        -- Daily rates
        CASE 
            WHEN COALESCE(s.emails_sent, 0) > 0 
            THEN ROUND((COALESCE(o.unique_openers, 0)::FLOAT / s.emails_sent) * 100, 2)
            ELSE 0 
        END AS daily_open_rate_pct,
        
        CASE 
            WHEN COALESCE(s.emails_sent, 0) > 0 
            THEN ROUND((COALESCE(r.unique_repliers, 0)::FLOAT / s.emails_sent) * 100, 2)
            ELSE 0 
        END AS daily_reply_rate_pct,
        
        CASE 
            WHEN COALESCE(s.emails_sent, 0) > 0 
            THEN ROUND((COALESCE(r.unique_bounces, 0)::FLOAT / s.emails_sent) * 100, 2)
            ELSE 0 
        END AS daily_bounce_rate_pct,
        
        CURRENT_TIMESTAMP() AS metrics_calculated_at
        
    FROM campaign_dates cd
    LEFT JOIN daily_sends s 
        ON cd.campaign_id = s.campaign_id 
        AND cd.activity_date = s.activity_date
    LEFT JOIN daily_opens o 
        ON cd.campaign_id = o.campaign_id 
        AND cd.activity_date = o.activity_date
    LEFT JOIN daily_replies r 
        ON cd.campaign_id = r.campaign_id 
        AND cd.activity_date = r.activity_date
    
    -- Only keep dates with actual activity
    WHERE COALESCE(s.emails_sent, 0) > 0 
       OR COALESCE(o.total_opens, 0) > 0 
       OR COALESCE(r.total_replies, 0) > 0
)

SELECT * FROM final
ORDER BY campaign_id, activity_date
    )

