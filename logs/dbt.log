parsed as (
    select
        -- ingestion metadata
        team_id,
        extracted_at,
        source_endpoint,

        -- primary identifier
        payload:id::bigint                     as reply_id,

        -- event metadata
        payload:actionDate::timestamp_ntz      as action_date,
        payload:object::string                 as object_type,
        payload:type::string                   as reply_type,
        payload:subject::string                as subject,

        -- external IDs
        payload:externalConversationID::string  as external_conversation_id,
        payload:externalID::string              as external_id,
        payload:externalRawMessageID::string    as external_raw_message_id,

        -- campaign info
        payload:campaign.id::int               as campaign_id,
        payload:campaign.title::string         as campaign_title,
        payload:campaign.object::string        as campaign_object,
        payload:campaign.wizardStatus::string  as campaign_wizard_status,

        -- parent sent message info
        payload:parent.id::bigint              as parent_sent_id,
        payload:parent.type::string            as parent_type,
        payload:parent.object::string          as parent_object,
        payload:parent.message.id::int         as parent_message_id,
        payload:parent.message.type::string    as parent_message_type,
        payload:parent.message.replyToID::int  as parent_reply_to_id,
        payload:parent.message.subject::string as parent_subject,

        -- from address info
        payload:from.address::string           as from_address,
        payload:from.first::string             as from_first_name,
        payload:from.last::string              as from_last_name,
        payload:from.fullName::string          as from_full_name,

        -- recipient info
        payload:recipient.id::int                   as recipient_id,
        payload:recipient.contactID::int           as recipient_contact_id,
        payload:recipient.emailAddress::string     as recipient_email,
        payload:recipient.first::string            as recipient_first_name,
        payload:recipient.last::string             as recipient_last_name,
        payload:recipient.fullName::string         as recipient_full_name,
        payload:recipient.created::timestamp_ntz   as recipient_created_at,
        payload:recipient.isPaused::boolean        as recipient_is_paused,

        -- recipient custom fields
        payload:recipient.fields.account::string    as account,
        payload:recipient.fields.position::string   as position,
        payload:recipient.fields.link::string       as job_link,
        payload:recipient.fields.phoneNumber::string as phone_number,
        payload:recipient.fields.linkedInUrl::string as linkedin_url,
        payload:recipient.fields.facebookUrl::string as facebook_url,
        payload:recipient.fields.instagramID::string as instagram_id,
        payload:recipient.fields.twitterID::string   as twitter_id,

        -- message body
        payload:body::string                  as html_body,
        payload:plainTextBody::string         as plain_text_body,
        payload:rawBody::string               as raw_body

    from source
),

deduped AS (
    SELECT *
    FROM parsed
    QUALIFY ROW_NUMBER() OVER (
        PARTITION BY reply_id, parent_sent_id
        ORDER BY extracted_at DESC
    ) = 1
)

SELECT *
FROM deduped
  )
