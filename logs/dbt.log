        JSON_VALUE(payload, '$.object') AS object_type

    FROM source
    -- Deduplication logic happens here 
    QUALIFY ROW_NUMBER() OVER (
        PARTITION BY JSON_VALUE(payload, '$.id') 
        ORDER BY extracted_at DESC
    ) = 1
)
select *
from parsed;


