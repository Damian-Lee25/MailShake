    as (

WITH campaigns AS (
    SELECT * FROM MAILSHAKE_DB.SILVER.stg_mailshake_campaigns
),

-- Get recipient counts per campaign (via activity bridge)
recipients AS (
    SELECT
        campaign_id,
        COUNT(DISTINCT recipient_id) AS total_recipients
    FROM MAILSHAKE_DB.SILVER.stg_mailshake_activity_sent
    GROUP BY campaign_id
),

-- Email send activity
activity_sent AS (
    SELECT 
        campaign_id,
        action_date,
        COUNT(*) AS total_sends,
        COUNT(DISTINCT recipient_id) AS unique_recipients_sent,
        MIN(action_date) AS first_send_at,
        MAX(action_date) AS last_send_at
    FROM MAILSHAKE_DB.SILVER.stg_mailshake_activity_sent
    GROUP BY campaign_id, action_date
),

-- Email open activity
activity_opens AS (
    SELECT 
        campaign_id,
        COUNT(*) AS total_opens,
        COUNT(DISTINCT recipient_id) AS unique_openers,
        MIN(action_date) AS first_open_at,
        MAX(action_date) AS last_open_at
    FROM MAILSHAKE_DB.SILVER.stg_mailshake_activity_opens
    GROUP BY campaign_id
),

-- Email replies - breakdown by type
activity_replies AS (
    SELECT 
        campaign_id,
        
        -- Actual replies (positive engagement)
        COUNT(CASE WHEN reply_type = 'reply' THEN 1 END) AS total_replies,
        COUNT(DISTINCT CASE WHEN reply_type = 'reply' THEN recipient_id END) AS unique_repliers,
        MIN(CASE WHEN reply_type = 'reply' THEN action_date END) AS first_reply_at,
        
        -- Bounces (deliverability issues)
        COUNT(CASE WHEN reply_type = 'bounce' THEN 1 END) AS total_bounces,
        COUNT(DISTINCT CASE WHEN reply_type = 'bounce' THEN recipient_id END) AS unique_bounces,
        
        -- Unsubscribes (negative signal)
        COUNT(CASE WHEN reply_type = 'unsubscribe' THEN 1 END) AS total_unsubscribes,
        COUNT(DISTINCT CASE WHEN reply_type = 'unsubscribe' THEN recipient_id END) AS unique_unsubscribes,
        
        -- Out-of-office (context, not negative)
        COUNT(CASE WHEN reply_type = 'out-of-office' THEN 1 END) AS total_out_of_office,
        COUNT(DISTINCT CASE WHEN reply_type = 'out-of-office' THEN recipient_id END) AS unique_out_of_office,
        
        -- Other types (for reference)
        COUNT(CASE WHEN reply_type = 'delay-notification' THEN 1 END) AS total_delay_notifications,
        COUNT(CASE WHEN reply_type = 'hit-quota' THEN 1 END) AS total_hit_quota
        
    FROM MAILSHAKE_DB.SILVER.stg_mailshake_activity_replies
    GROUP BY campaign_id
),

-- Calculate average response time for actual replies
reply_timing AS (
    SELECT
        s.campaign_id,
        AVG(DATEDIFF(hour, s.action_date, r.action_date)) AS avg_hours_to_reply,
        MEDIAN(DATEDIFF(hour, s.action_date, r.action_date)) AS median_hours_to_reply
    FROM MAILSHAKE_DB.SILVER.stg_mailshake_activity_sent s
    INNER JOIN MAILSHAKE_DB.SILVER.stg_mailshake_activity_replies r
        ON s.recipient_id = r.recipient_id
        AND s.campaign_id = r.campaign_id
        AND r.reply_type = 'reply'
    GROUP BY s.campaign_id
),

-- Assemble final metrics
final AS (
    SELECT
        -- Campaign identifiers
        c.campaign_id,
        c.team_id,
        c.campaign_title,
        c.created_at AS campaign_created_at,
        c.wizard_status,
        
        -- Sender information
        c.sender_id,
        c.sender_email,
        c.sender_from_name,
        
        -- Campaign attributes
        c.is_archived,
        c.is_paused,
        
        -- Volume metrics
        COALESCE(r.total_recipients, 0) AS total_recipients,
        COALESCE(s.total_sends, 0) AS emails_sent,
        COALESCE(s.total_sends, 0) - COALESCE(rp.total_bounces, 0) AS emails_delivered,
        
        -- Engagement volumes
        COALESCE(o.total_opens, 0) AS total_opens,
        COALESCE(o.unique_openers, 0) AS unique_openers,
        COALESCE(rp.total_replies, 0) AS total_replies,
        COALESCE(rp.unique_repliers, 0) AS unique_repliers,
        
        -- Problem volumes
        COALESCE(rp.total_bounces, 0) AS total_bounces,
        COALESCE(rp.unique_bounces, 0) AS unique_bounces,
        COALESCE(rp.total_unsubscribes, 0) AS total_unsubscribes,
        COALESCE(rp.unique_unsubscribes, 0) AS unique_unsubscribes,
        
        -- Context volumes
        COALESCE(rp.total_out_of_office, 0) AS total_out_of_office,
        COALESCE(rp.unique_out_of_office, 0) AS unique_out_of_office,
        
        -- Timing metrics
        s.first_send_at,
        s.last_send_at,
        o.first_open_at,
        o.last_open_at,
        rp.first_reply_at,
        
        -- Response time metrics (hours)
        COALESCE(rt.avg_hours_to_reply, 0) AS avg_hours_to_reply,
        COALESCE(rt.median_hours_to_reply, 0) AS median_hours_to_reply,
        
        -- Calculate time to first engagement (hours)
        CASE 
            WHEN o.first_open_at IS NOT NULL 
            THEN DATEDIFF(hour, s.first_send_at, o.first_open_at)
            ELSE NULL 
        END AS hours_to_first_open,
        
        CASE 
            WHEN rp.first_reply_at IS NOT NULL 
            THEN DATEDIFF(hour, s.first_send_at, rp.first_reply_at)
            ELSE NULL 
        END AS hours_to_first_reply,
        
        -- PERFORMANCE RATES (%)
        
        -- Deliverability Rate: % of emails that reached inbox
        CASE 
            WHEN s.total_sends > 0 
            THEN ROUND(((s.total_sends - COALESCE(rp.total_bounces, 0))::FLOAT / s.total_sends) * 100, 2)
            ELSE 0 
        END AS deliverability_rate_pct,
        
        -- Open Rate: % of sent emails that were opened
        CASE 
            WHEN s.total_sends > 0 
            THEN ROUND((o.unique_openers::FLOAT / s.total_sends) * 100, 2)
            ELSE 0 
        END AS open_rate_pct,
        
        -- Reply Rate: % of sent emails that got actual replies
        CASE 
            WHEN s.total_sends > 0 
            THEN ROUND((rp.unique_repliers::FLOAT / s.total_sends) * 100, 2)
            ELSE 0 
        END AS reply_rate_pct,
        
        -- Bounce Rate: % of emails that bounced
        CASE 
            WHEN s.total_sends > 0 
            THEN ROUND((rp.unique_bounces::FLOAT / s.total_sends) * 100, 2)
            ELSE 0 
        END AS bounce_rate_pct,
        
        -- Unsubscribe Rate: % of emails that resulted in unsubscribe
        CASE 
            WHEN s.total_sends > 0 
            THEN ROUND((rp.unique_unsubscribes::FLOAT / s.total_sends) * 100, 2)
            ELSE 0 
        END AS unsubscribe_rate_pct,
        
        -- Reply-to-Open Rate: Of those who opened, what % replied?
        CASE 
            WHEN o.unique_openers > 0 
            THEN ROUND((rp.unique_repliers::FLOAT / o.unique_openers) * 100, 2)
            ELSE 0 
        END AS reply_to_open_rate_pct,
        
        -- ENGAGEMENT SCORE (0-100)
        -- Formula: Weighted composite of positive actions minus negative signals
        -- Opens (30%) + Replies (50%) - Bounces (10%) - Unsubscribes (10%)
        CASE 
            WHEN s.total_sends > 0 
            THEN GREATEST(0, ROUND(
                (0.30 * ((o.unique_openers::FLOAT / s.total_sends) * 100)) +
                (0.50 * ((rp.unique_repliers::FLOAT / s.total_sends) * 100)) -
                (0.10 * ((rp.unique_bounces::FLOAT / s.total_sends) * 100)) -
                (0.10 * ((rp.unique_unsubscribes::FLOAT / s.total_sends) * 100)),
                2
            ))
            ELSE 0 
        END AS engagement_score,
        
        -- EFFICIENCY RATE (0-100)
        -- Overall campaign effectiveness: combines deliverability + engagement
        -- Formula: (Deliverability * 0.4) + (Open Rate * 0.3) + (Reply Rate * 0.3)
        CASE 
            WHEN s.total_sends > 0 
            THEN ROUND(
                (0.40 * (((s.total_sends - COALESCE(rp.total_bounces, 0))::FLOAT / s.total_sends) * 100)) +
                (0.30 * ((o.unique_openers::FLOAT / s.total_sends) * 100)) +
                (0.30 * ((rp.unique_repliers::FLOAT / s.total_sends) * 100)),
                2
            )
            ELSE 0 
        END AS efficiency_rate_pct,
        
        -- ENGAGEMENT TIER CLASSIFICATION
        CASE 
            WHEN s.total_sends = 0 THEN 'No Activity'
            WHEN (
                (0.30 * ((o.unique_openers::FLOAT / s.total_sends) * 100)) +
                (0.50 * ((rp.unique_repliers::FLOAT / s.total_sends) * 100)) -
                (0.10 * ((rp.unique_bounces::FLOAT / s.total_sends) * 100)) -
                (0.10 * ((rp.unique_unsubscribes::FLOAT / s.total_sends) * 100))
            ) >= 30 THEN 'High Engagement'
            WHEN (
                (0.30 * ((o.unique_openers::FLOAT / s.total_sends) * 100)) +
                (0.50 * ((rp.unique_repliers::FLOAT / s.total_sends) * 100)) -
                (0.10 * ((rp.unique_bounces::FLOAT / s.total_sends) * 100)) -
                (0.10 * ((rp.unique_unsubscribes::FLOAT / s.total_sends) * 100))
            ) >= 15 THEN 'Medium Engagement'
            ELSE 'Low Engagement'
        END AS engagement_tier,
        
        -- HEALTH STATUS
        CASE
            WHEN s.total_sends = 0 THEN 'Inactive'
            WHEN (rp.unique_bounces::FLOAT / NULLIF(s.total_sends, 0)) > 0.10 THEN 'Poor Deliverability'
            WHEN (rp.unique_unsubscribes::FLOAT / NULLIF(s.total_sends, 0)) > 0.05 THEN 'High Unsubscribe Risk'
            WHEN (rp.unique_repliers::FLOAT / NULLIF(s.total_sends, 0)) > 0.10 THEN 'Healthy - High Reply'
            WHEN (o.unique_openers::FLOAT / NULLIF(s.total_sends, 0)) > 0.20 THEN 'Healthy - Good Open'
            ELSE 'Needs Optimization'
        END AS campaign_health_status,
        
        -- Metadata
        CURRENT_TIMESTAMP() AS metrics_calculated_at
        
    FROM campaigns c
    LEFT JOIN recipients r ON c.campaign_id = r.campaign_id
    LEFT JOIN activity_sent s ON c.campaign_id = s.campaign_id
    LEFT JOIN activity_opens o ON c.campaign_id = o.campaign_id
    LEFT JOIN activity_replies rp ON c.campaign_id = rp.campaign_id
    LEFT JOIN reply_timing rt ON c.campaign_id = rt.campaign_id
)

SELECT * FROM final
    )

