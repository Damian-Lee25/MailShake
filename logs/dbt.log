        payload:emailAddress::string          as sender_email,
        payload:fromName::string              as sender_name,
        payload:created::timestamp_ntz        as created_at,
        payload:object::string                as object_type

    from source
    
    QUALIFY ROW_NUMBER() OVER (
        PARTITION BY sender_id
        ORDER BY extracted_at DESC
    ) = 1

)

select *
from parsed
  )
