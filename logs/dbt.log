WITH source AS (
    SELECT * FROM `MAILSHAKE_DB`.`BRONZE`.`campaigns`
),

parsed AS (
    SELECT
        -- Bronze metadata
        team_id,
        extracted_at,
        source_endpoint,
        
        -- Campaign attributes
        payload:id::INT AS campaign_id, -- Renamed for cleaner joins
        payload:created::TIMESTAMP_NTZ AS created_at,
        payload:title::STRING AS campaign_title,
        payload:object::STRING AS object_type,
        payload:url::STRING AS campaign_url,
        payload:wizardStatus::STRING AS wizard_status,
        payload:isArchived::BOOLEAN AS is_archived,
        payload:isPaused::BOOLEAN AS is_paused,
        
        -- Sender info
        payload:sender.id::STRING AS sender_id,
        payload:sender.emailAddress::STRING AS sender_email,
        payload:sender.fromName::STRING AS sender_from_name,
        payload:sender.created::TIMESTAMP_NTZ AS sender_created_at,
        
        -- Messages array
        payload:messages AS messages_json
        
    FROM source
    -- Deduplication logic happens here
    QUALIFY ROW_NUMBER() OVER (
        PARTITION BY campaign_id 
        ORDER BY extracted_at DESC
    ) = 1
)

SELECT * FROM parsed;


